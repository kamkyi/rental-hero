{
  "expo": {
    "name": "Rental Hero",
    "slug": "rental-hero",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rentalhero",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F6F3EC"
    },
    "ios": {
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Rental Hero uses your location to suggest nearby pickup cities and improve local car availability."
      },
      "supportsTablet": true
    },
    "android": {
      "permissions": ["ACCESS_COARSE_LOCATION", "ACCESS_FINE_LOCATION"],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Rental Hero uses your location to suggest nearby pickup cities and improve local car availability."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
